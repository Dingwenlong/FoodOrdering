/** app.wxss **/
page {
  /* 玻璃态基础变量 - 小程序端 */
  --bg-dark: #0f172a; /* Slate-900 */
  --glass-bg: rgba(255, 255, 255, 0.08);
  --glass-border: rgba(255, 255, 255, 0.12);
  --glass-text-main: #ffffff;
  --glass-text-sub: rgba(255, 255, 255, 0.6);
  --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);

  /* 霓虹品牌色 */
  --neon-cyan: #22d3ee;
  --neon-purple: #a855f7;
  --neon-pink: #f472b6;

  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;

  --tap-min: 88rpx;
  --font-body: 28rpx;
  --font-title: 32rpx;
  --line-body: 1.4;
  --page-px: 32rpx;
  --page-py: 32rpx;
  --safe-bottom-gap: 24rpx; /* 基础留白，用于普通机型 */
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --safe-top: env(safe-area-inset-top, 0px);
  --content-max-width: 100%;
  
  /* 全局深色渐变背景 */
  background: radial-gradient(at 0% 0%, #1a1a2e 0, transparent 50%), 
              radial-gradient(at 50% 0%, #16213e 0, transparent 50%), 
              radial-gradient(at 100% 0%, #1f4068 0, transparent 50%),
              #0f172a; /* Fallback color */
  background-attachment: fixed;
  background-size: cover;
  color: var(--glass-text-main);
  box-sizing: border-box;
  min-height: 100vh;
  font-size: var(--font-body);
  line-height: var(--line-body);
  overflow-x: hidden;
}

@media (min-width: 415px) {
  page {
    --page-px: 40rpx;
  }
}

@media (min-width: 768px) {
  page {
    --page-px: 48rpx;
    --font-title: 36rpx;
    --content-max-width: 900rpx;
  }
}

view,
text,
scroll-view,
input,
textarea,
button,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  min-width: var(--tap-min);
  min-height: var(--tap-min);
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: var(--font-body);
  line-height: var(--line-body);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

button::after {
  border: none;
}

button[disabled] {
  opacity: 0.55;
}

input,
textarea {
  font-size: var(--font-body);
  line-height: var(--line-body);
  min-height: var(--tap-min);
}

.safe-area-sides {
  padding-left: var(--page-px);
  padding-right: var(--page-px);
}

.safe-area-bottom {
  padding-bottom: calc(var(--safe-bottom-gap) + var(--safe-bottom));
}

.safe-area {
  padding-left: var(--page-px);
  padding-right: var(--page-px);
  padding-bottom: calc(var(--safe-bottom-gap) + var(--safe-bottom));
}

.page-root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  min-height: 0;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 玻璃态卡片通用类 */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid var(--glass-border);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  color: var(--glass-text-main);
}

/* 霓虹渐变按钮 */
.neon-btn {
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.8), rgba(59, 130, 246, 0.8)) !important;
  color: #fff !important;
  border: none !important;
  box-shadow: 0 4rpx 16rpx rgba(34, 211, 238, 0.4);
  font-weight: bold;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.neon-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 次级玻璃按钮 */
.glass-btn-secondary {
  background: rgba(255, 255, 255, 0.1) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.2) !important;
  color: rgba(255, 255, 255, 0.8) !important;
  border-radius: 16rpx;
}

/* 价格字体 */
.price-font {
  font-family: 'DIN Alternate', 'Roboto', sans-serif;
  font-weight: bold;
}

/* 无障碍触控区 */
.touch-target {
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
