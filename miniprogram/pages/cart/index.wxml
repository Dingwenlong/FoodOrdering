<view class="container">
  <scroll-view class="cart-list" scroll-y wx:if="{{items.length > 0}}">
    <view class="list-header">
      <text class="list-title">购物车</text>
      <text class="clear-btn" bindtap="clearCart">清空</text>
    </view>

    <view class="error-box" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <view wx:for="{{items}}" wx:key="dishId" class="cart-item glass-card">
      <view class="item-info">
        <text class="name">{{item.dishName}}</text>
        <view class="price-wrap">
          <text class="currency">¥</text>
          <text class="price price-font">{{item.unitPriceFen / 100}}</text>
        </view>
      </view>

      <view class="stepper">
        <view
          class="btn-minus touch-target"
          bindtap="updateQty"
          data-id="{{item.dishId}}"
          data-delta="{{-1}}"
          hover-class="btn-active"
        >-</view>

        <text class="qty">{{item.qty}}</text>

        <view
          class="btn-plus touch-target"
          bindtap="updateQty"
          data-id="{{item.dishId}}"
          data-delta="{{1}}"
          hover-class="btn-active"
        >+</view>
      </view>
    </view>

    <view class="remark-panel glass-card">
      <view class="remark-header">
        <text class="remark-title">订单备注</text>
        <text class="remark-count">{{remarkLength}}/{{remarkLimit}}</text>
      </view>
      <textarea
        class="remark-input"
        value="{{remark}}"
        maxlength="{{remarkLimit}}"
        bindinput="handleRemarkInput"
        placeholder="可填写忌口、口味、上菜节奏等"
        placeholder-class="remark-placeholder"
      />
    </view>

    <view style="height: 220rpx"></view>
  </scroll-view>

  <view class="empty-cart" wx:else>
    <view class="empty-icon-wrapper">
      <text class="empty-icon">🛒</text>
    </view>
    <text class="empty-text">购物车空空如也</text>
    <button class="go-back-btn neon-btn" bindtap="goBack" hover-class="btn-hover">
      去点餐
    </button>
  </view>

  <view class="footer glass-card-no-radius safe-area-bottom" wx:if="{{items.length > 0}}">
    <view class="amount-lines">
      <view class="amount-row">
        <text class="row-label">小计</text>
        <text class="row-value">¥{{totalPrice / 100}}</text>
      </view>
      <view class="amount-row">
        <text class="row-label">服务费</text>
        <text class="row-value">¥{{serviceFee / 100}}</text>
      </view>
      <view class="amount-row total">
        <text class="row-label">合计</text>
        <text class="row-value">¥{{payablePrice / 100}}</text>
      </view>
    </view>

    <button
      class="submit-btn neon-btn"
      bindtap="submitOrder"
      loading="{{submitting}}"
      hover-class="btn-hover"
      disabled="{{submitting}}"
    >
      提交订单
    </button>
  </view>
</view>
