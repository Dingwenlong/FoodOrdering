.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.list-header {
  padding: 40rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 1rpx;
}

.cart-list {
  flex: 1;
  padding: 0 32rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.item-info {
  flex: 1;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
}

.price-wrap {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
}

.currency {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
}

/* 复用 Stepper 样式 */
.stepper {
  display: flex;
  align-items: center;
}

.btn-minus, .btn-plus {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: transform 0.1s;
}

.btn-minus {
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.6);
  background: transparent;
}

.btn-plus {
  background: var(--neon-cyan);
  color: #000;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.4);
}

.btn-active {
  transform: scale(0.9);
}

.qty {
  min-width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

/* 底部栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.total-area {
  display: flex;
  align-items: baseline;
}

.label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-right: 12rpx;
}

.total-price {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
}

.total-price .currency {
  font-size: 28rpx;
}

.total-price .amount {
  font-size: 48rpx;
}

.submit-btn {
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
  width: 260rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  margin-bottom: 60rpx;
}

.go-back-btn {
  width: 260rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
}
