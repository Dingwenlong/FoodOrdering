.container {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.list-header {
  padding: 40rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 1rpx;
}



.cart-list {
  flex: 1;
  padding: 0 32rpx;
  min-width: 0;
  box-sizing: border-box;
  overflow-x: hidden;
}

.error-box {
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.52);
  background: rgba(248, 113, 113, 0.14);
  color: #ffe4e6;
  font-size: 28rpx;
  padding: 12rpx 14rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  animation: slideIn 0.3s ease-out;
  overflow: hidden;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.item-info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-wrap {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
}

.currency {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
}

.stepper {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.stepper .touch-target {
  min-width: 64rpx;
  min-height: 64rpx;
}

.btn-minus,
.btn-plus {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: transform 0.1s;
}

.btn-minus {
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.6);
  background: transparent;
}

.btn-plus {
  background: var(--neon-cyan);
  color: #000;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.4);
}

.btn-active {
  transform: scale(0.9);
}

.qty {
  min-width: 52rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.remark-panel {
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.remark-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.remark-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.remark-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.45);
}

.remark-input {
  width: 100%;
  min-height: 176rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.44);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: #fff;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.45;
}

.remark-placeholder {
  color: rgba(255, 255, 255, 0.34);
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(15, 23, 42, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + var(--safe-bottom-gap) + var(--safe-bottom));
  z-index: 100;
}

.amount-lines {
  margin-bottom: 18rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.amount-row .row-label {
  color: rgba(255, 255, 255, 0.6);
}

.amount-row .row-value {
  color: #fff;
}

.amount-row.total {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.amount-row.total .row-value {
  color: var(--neon-cyan);
}

.submit-btn {
  margin: 0;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
  width: 100%;
  height: 90rpx;
  border-radius: 45rpx;
  box-sizing: border-box;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  margin-bottom: 60rpx;
}

.go-back-btn {
  width: 68%;
  min-width: 240rpx;
  max-width: 340rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  margin: 0;
  box-sizing: border-box;
}
