.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: transparent; /* 透出全局渐变背景 */
}

/* 顶部 Header */
.header {
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  z-index: 10;
  flex-shrink: 0;
}

.glass-card-no-radius {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.store-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  margin-right: 16rpx;
  letter-spacing: 1rpx;
}

.store-status {
  font-size: 20rpx;
  color: var(--neon-cyan);
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.table-tag {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.table-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.table-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

/* 主体内容区 */
.content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类 */
.sidebar {
  width: 180rpx;
  background: rgba(0, 0, 0, 0.2);
  height: 100%;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
}

.category-item {
  position: relative;
  padding: 36rpx 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  transition: all 0.3s;
}

.category-item.active {
  background: rgba(255, 255, 255, 0.05);
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.active-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: var(--neon-cyan);
  box-shadow: 0 0 12rpx var(--neon-cyan);
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧列表 */
.menu-list {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
}

.category-section {
  padding-top: 20rpx;
}

.category-title {
  padding: 24rpx 0;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.dish-item {
  display: flex;
  margin-bottom: 24rpx;
  padding: 24rpx;
  /* glass-card 已包含背景与边框 */
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.dish-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-area {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
}

.currency {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.price {
  font-size: 36rpx;
}

/* 加减按钮 */
.stepper {
  display: flex;
  align-items: center;
}

.btn-minus, .btn-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx; /* 方形圆角更具科技感 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: transform 0.1s;
}

.btn-minus {
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.7);
  background: transparent;
}

.btn-plus {
  background: var(--neon-cyan);
  color: #000;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.4);
}

.btn-active {
  transform: scale(0.9);
}

.count {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin: 0 10rpx;
}

/* 购物车条 */
.cart-bar-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
  transform: translateY(150%);
  transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
}

.cart-bar-wrapper.show {
  transform: translateY(0);
}

.cart-bar {
  height: 110rpx;
  /* glass-card 样式覆盖 */
  background: rgba(20, 20, 30, 0.6); 
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  padding-left: 160rpx;
  padding-right: 10rpx;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.cart-icon-wrapper {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 130rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1e293b, #0f172a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: var(--neon-pink);
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-weight: bold;
  box-shadow: 0 0 10rpx var(--neon-pink);
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cart-total {
  color: #fff;
  font-size: 36rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.2);
}

.cart-total .currency {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.delivery-tip {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.checkout-btn {
  width: 200rpx;
  height: 90rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.2s ease-out;
}

.scale-in {
  animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes scaleIn {
  from { transform: scale(0); }
  to { transform: scale(1); }
}
