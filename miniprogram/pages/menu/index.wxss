.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: transparent;
}

.header {
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  z-index: 10;
  flex-shrink: 0;
}

.glass-card-no-radius {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.store-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  margin-right: 16rpx;
  letter-spacing: 1rpx;
}

.store-status {
  font-size: 20rpx;
  color: var(--neon-cyan);
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.table-tag {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.table-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.table-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-input {
  flex: 1;
  height: 68rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(15, 23, 42, 0.42);
  color: #fff;
  padding: 0 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.search-clear {
  margin: 0;
  width: 104rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.error-box {
  margin: 14rpx 24rpx 0;
  border-radius: 12rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.5);
  background: rgba(248, 113, 113, 0.14);
  color: #ffe4e6;
  font-size: 24rpx;
  padding: 14rpx 16rpx;
}

.loading-box {
  margin: 36rpx auto;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
}

.content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.sidebar {
  width: 180rpx;
  background: rgba(0, 0, 0, 0.2);
  height: 100%;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
}

.category-item {
  position: relative;
  padding: 36rpx 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  transition: all 0.3s;
}

.category-item.active {
  background: rgba(255, 255, 255, 0.05);
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.active-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: var(--neon-cyan);
  box-shadow: 0 0 12rpx var(--neon-cyan);
  border-radius: 0 4rpx 4rpx 0;
}

.menu-list {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
}

.empty-state {
  margin-top: 80rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-section {
  padding-top: 20rpx;
}

.category-title {
  padding: 24rpx 0;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  letter-spacing: 2rpx;
}

.dish-item {
  display: flex;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.sold-out {
  font-size: 20rpx;
  color: #fecaca;
  border: 1rpx solid rgba(248, 113, 113, 0.7);
  background: rgba(248, 113, 113, 0.2);
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}

.dish-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.action-area {
  display: flex;
  align-items: center;
  column-gap: 10rpx;
}

.spec-btn {
  margin: 0;
  width: 118rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.spec-btn[disabled] {
  opacity: 0.45;
}

.price-area {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
}

.currency {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.price {
  font-size: 36rpx;
}

.stepper {
  display: flex;
  align-items: center;
}

.btn-minus,
.btn-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: transform 0.1s;
}

.btn-minus {
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.7);
  background: transparent;
}

.btn-plus {
  background: var(--neon-cyan);
  color: #000;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.4);
}

.btn-plus.disabled {
  background: rgba(148, 163, 184, 0.4);
  color: rgba(255, 255, 255, 0.5);
  box-shadow: none;
}

.btn-active {
  transform: scale(0.9);
}

.count {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin: 0 10rpx;
}

.cart-bar-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
  transform: translateY(150%);
  transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
}

.cart-bar-wrapper.show {
  transform: translateY(0);
}

.cart-bar {
  height: 110rpx;
  background: rgba(20, 20, 30, 0.6);
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  padding-left: 160rpx;
  padding-right: 10rpx;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.cart-icon-wrapper {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 130rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1e293b, #0f172a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: var(--neon-pink);
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-weight: bold;
  box-shadow: 0 0 10rpx var(--neon-pink);
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cart-total {
  color: #fff;
  font-size: 36rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.2);
}

.cart-total .currency {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.delivery-tip {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.checkout-btn {
  width: 200rpx;
  height: 90rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
}

.spec-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.58);
  z-index: 160;
}

.spec-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 170;
  padding: 0 22rpx calc(22rpx + env(safe-area-inset-bottom));
}

.spec-card {
  border-radius: 28rpx 28rpx 20rpx 20rpx;
  padding: 26rpx;
}

.spec-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.spec-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.spec-price {
  font-size: 30rpx;
  color: var(--neon-cyan);
  font-weight: 700;
}

.spec-section {
  margin-bottom: 20rpx;
}

.spec-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 10rpx;
}

.taste-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.taste-chip {
  min-width: 120rpx;
  text-align: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  background: rgba(255, 255, 255, 0.08);
}

.taste-chip.active {
  color: #022c22;
  border-color: rgba(16, 185, 129, 0.2);
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.9), rgba(45, 212, 191, 0.9));
}

.spec-stepper {
  display: inline-flex;
  align-items: center;
  column-gap: 16rpx;
}

.spec-qty {
  min-width: 56rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.spec-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 14rpx;
}

.spec-cancel,
.spec-confirm {
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.spec-cancel {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  color: #fff;
}
