.container {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: transparent;
  max-width: var(--content-max-width);
  margin: 0 auto;
}

.header {
  height: 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 var(--page-px);
  z-index: 10;
  flex-shrink: 0;
}

.glass-card-no-radius {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.store-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  margin-right: 16rpx;
  letter-spacing: 1rpx;
}

.store-status {
  font-size: 28rpx;
  color: var(--neon-cyan);
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  padding: 0 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.table-tag {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 0 20rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.table-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.table-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx var(--page-px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  min-height: var(--tap-min);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(15, 23, 42, 0.42);
  color: #fff;
  padding: 0 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.search-clear {
  margin: 0;
  width: 132rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.error-box {
  margin: 14rpx var(--page-px) 0;
  border-radius: 12rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.5);
  background: rgba(248, 113, 113, 0.14);
  color: #ffe4e6;
  font-size: 28rpx;
  padding: 14rpx 16rpx;
  flex-shrink: 0;
}

.loading-box {
  margin: 36rpx auto;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.65);
  flex-shrink: 0;
}

.content {
  flex: 1;
  min-height: 0;
  display: flex;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.sidebar {
  width: 176rpx;
  background: rgba(0, 0, 0, 0.2);
  height: 100%;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
  flex-shrink: 0;
  box-sizing: border-box;
}

.category-item {
  position: relative;
  padding: 32rpx 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  transition: all 0.3s;
}

.category-item.active {
  background: rgba(255, 255, 255, 0.05);
  color: #fff;
  font-weight: bold;
  font-size: 30rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.active-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: var(--neon-cyan);
  box-shadow: 0 0 12rpx var(--neon-cyan);
  border-radius: 0 4rpx 4rpx 0;
}

.menu-list {
  flex: 1;
  height: 100%;
  min-width: 0;
  padding: 0 20rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.empty-state {
  margin-top: 80rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-section {
  padding-top: 20rpx;
}

.category-title {
  padding: 24rpx 0;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  letter-spacing: 2rpx;
}

.dish-item {
  display: flex;
  margin-bottom: 24rpx;
  padding: 24rpx;
  overflow: hidden;
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sold-out {
  font-size: 28rpx;
  color: #fecaca;
  border: 1rpx solid rgba(248, 113, 113, 0.7);
  background: rgba(248, 113, 113, 0.2);
  padding: 0 14rpx;
  border-radius: 999rpx;
}

.dish-desc {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  column-gap: 12rpx;
}

.action-area {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  column-gap: 10rpx;
  min-width: 0;
  max-width: 56%;
}

.spec-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  white-space: nowrap;
}

.spec-btn {
  margin: 0;
  width: auto;
  min-width: 112rpx;
  max-width: 180rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  white-space: nowrap;
  box-sizing: border-box;
  flex-shrink: 1;
}

.spec-btn[disabled] {
  opacity: 0.45;
}

.price-area {
  color: var(--neon-cyan);
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 10rpx rgba(34, 211, 238, 0.3);
  flex-shrink: 0;
}

.currency {
  font-size: 28rpx;
  margin-right: 2rpx;
}

.price {
  font-size: 36rpx;
}

.stepper {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.stepper .touch-target {
  min-width: 64rpx;
  min-height: 64rpx;
}

.btn-minus,
.btn-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: transform 0.1s;
}

.btn-minus {
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.7);
  background: transparent;
}

.btn-plus {
  background: var(--neon-cyan);
  color: #000;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.4);
}

.btn-plus.disabled {
  background: rgba(148, 163, 184, 0.4);
  color: rgba(255, 255, 255, 0.5);
  box-shadow: none;
}

.btn-active {
  transform: scale(0.9);
}

.count {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin: 0 10rpx;
}

.cart-bar-wrapper {
  position: fixed;
  bottom: calc(var(--safe-bottom-gap) + var(--safe-bottom));
  left: var(--page-px);
  right: var(--page-px);
  z-index: 100;
  transform: translateY(150%);
  transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
}

.cart-bar-wrapper.show {
  transform: translateY(0);
}

.cart-bar {
  height: 110rpx;
  background: rgba(20, 20, 30, 0.6);
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  padding-left: 160rpx;
  padding-right: 10rpx;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.cart-icon-wrapper {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 130rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1e293b, #0f172a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: var(--neon-pink);
  color: #fff;
  font-size: 28rpx;
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-weight: bold;
  box-shadow: 0 0 10rpx var(--neon-pink);
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cart-total {
  color: #fff;
  font-size: 36rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.2);
}

.cart-total .currency {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.delivery-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.checkout-btn {
  width: 32%;
  min-width: 168rpx;
  max-width: 220rpx;
  padding: 0 18rpx;
  height: 90rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
  box-sizing: border-box;
}

.spec-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.58);
  z-index: 160;
}

.spec-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 170;
  padding: 0 var(--page-px) calc(22rpx + var(--safe-bottom-gap) + var(--safe-bottom));
}

.spec-card {
  border-radius: 28rpx 28rpx 20rpx 20rpx;
  padding: 26rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.spec-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.spec-body {
  flex: 1;
  min-height: 0;
  height: 1px;
  padding-bottom: 20rpx;
}

.spec-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.spec-price {
  font-size: 30rpx;
  color: var(--neon-cyan);
  font-weight: 700;
}

.spec-section {
  margin-bottom: 20rpx;
}

.spec-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 10rpx;
}

.taste-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.taste-chip {
  min-width: 160rpx;
  text-align: center;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  background: rgba(255, 255, 255, 0.08);
}

.taste-chip.active {
  color: #022c22;
  border-color: rgba(16, 185, 129, 0.2);
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.9), rgba(45, 212, 191, 0.9));
}

.spec-stepper {
  display: inline-flex;
  align-items: center;
  column-gap: 16rpx;
}

.spec-stepper .touch-target {
  min-width: 72rpx;
  min-height: 72rpx;
}

.spec-qty {
  min-width: 56rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.spec-selected {
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.spec-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: 14rpx;
  align-items: stretch;
  min-width: 0;
}

.spec-cancel,
.spec-confirm {
  margin: 0;
  width: 100%;
  min-width: 0;
  padding: 0 12rpx;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.spec-cancel {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  color: #fff;
}

@media (max-width: 360px) {
  .spec-actions {
    column-gap: 10rpx;
  }

  .spec-cancel,
  .spec-confirm {
    font-size: 26rpx;
    padding: 0 8rpx;
  }
}
