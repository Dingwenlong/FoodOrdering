.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  max-width: var(--content-max-width);
  margin: 0 auto;
}

.content-scroll {
  padding: var(--page-py) var(--page-px);
}

.loading-state,
.error-state {
  margin: 120rpx auto 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.loading-state {
  color: rgba(255, 255, 255, 0.7);
}

.error-state {
  color: #fecaca;
  border: 1rpx solid rgba(248, 113, 113, 0.52);
  border-radius: 12rpx;
  padding: 18rpx;
  background: rgba(248, 113, 113, 0.14);
}

.status-card-wrapper {
  margin-bottom: 24rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  position: relative;
  overflow: hidden;
  min-width: 0;
}

.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.status-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  filter: blur(80rpx);
  opacity: 0.22;
  border-radius: 50%;
  z-index: -1;
}

.status-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-left: 20rpx;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.2);
}

.status-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 50rpx;
}

.progress-bar {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.step {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.step.active {
  background-color: var(--neon-cyan);
  border-color: var(--neon-cyan);
  box-shadow: 0 0 16rpx var(--neon-cyan);
}

.line {
  flex: 1;
  height: 4rpx;
  background-color: rgba(255, 255, 255, 0.1);
  margin: 0 8rpx;
}

.line.active {
  background-color: var(--neon-cyan);
  box-shadow: 0 0 8rpx var(--neon-cyan);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.order-info {
  margin-bottom: 24rpx;
  padding: 32rpx;
  min-width: 0;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  color: #fff;
  letter-spacing: 1rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background-color: var(--neon-purple);
  margin-right: 16rpx;
  border-radius: 4rpx;
  box-shadow: 0 0 10rpx var(--neon-purple);
}

.order-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #fff;
  min-width: 0;
  column-gap: 14rpx;
}

.item-name {
  flex: 1;
  min-width: 0;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-qty {
  min-width: 72rpx;
  text-align: right;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
}

.item-price {
  min-width: 140rpx;
  text-align: right;
  font-weight: bold;
  flex-shrink: 0;
}

.divider {
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.1);
  margin: 32rpx 0;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
}

.total-amount {
  color: var(--neon-cyan);
  font-size: 40rpx;
  display: flex;
  align-items: baseline;
  text-shadow: 0 0 16rpx rgba(34, 211, 238, 0.3);
}

.total-amount .currency {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.order-meta {
  padding: 32rpx;
  min-width: 0;
  overflow: hidden;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  column-gap: 20rpx;
  min-width: 0;
}

.meta-row:last-child {
  margin-bottom: 0;
}

.label {
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.value {
  color: #fff;
  font-weight: 500;
  text-align: right;
  min-width: 0;
  flex: 1;
  word-break: break-all;
}

.copyable:active {
  opacity: 0.6;
}

.icon-copy {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.footer-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + var(--safe-bottom-gap) + var(--safe-bottom));
  background: rgba(15, 23, 42, 0.84);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 100;
  box-sizing: border-box;
  overflow: hidden;
}

.pay-btn {
  margin: 0;
  width: 100%;
  min-width: 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 18rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  align-items: stretch;
}

.action-grid.triple {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.full-row {
  grid-column: 1 / -1;
}

.secondary-btn {
  margin: 0;
  width: 100%;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
  padding: 0 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.urge-btn {
  border-color: rgba(245, 158, 11, 0.45);
  background: rgba(245, 158, 11, 0.2);
  color: #fde68a;
}

@media (max-width: 360px) {
  .container {
    padding: 24rpx;
    padding-bottom: calc(116rpx + env(safe-area-inset-bottom));
  }

  .footer-action {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .pay-btn,
  .secondary-btn {
    font-size: 26rpx;
  }
}
