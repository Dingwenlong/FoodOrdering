.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
}



.loading-state,
.error-state,
.empty-state {
  margin-top: 140rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.error-state {
  color: #fecaca;
}

.primary-btn {
  margin-top: 24rpx;
  width: 320rpx;
  height: 84rpx;
  border-radius: 42rpx;
}

.list {
  max-height: calc(100vh - 180rpx);
}

.order-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.order-top,
.order-meta,
.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-top {
  margin-bottom: 14rpx;
}

.order-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.order-id {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.status-PENDING_PAY {
  color: #fcd34d;
  border-color: rgba(252, 211, 77, 0.5);
}

.status-PAID,
.status-COOKING {
  color: #86efac;
  border-color: rgba(134, 239, 172, 0.5);
}

.status-DONE {
  color: #67e8f9;
  border-color: rgba(103, 232, 249, 0.5);
}

.status-CANCELED {
  color: #fca5a5;
  border-color: rgba(252, 165, 165, 0.5);
}

.amount {
  color: var(--neon-cyan);
  font-size: 34rpx;
  font-weight: 800;
}

.detail-link {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}
