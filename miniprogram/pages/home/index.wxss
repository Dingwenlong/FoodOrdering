.container {
  min-height: 100vh;
  padding: 32rpx;
  background-color: transparent;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 160rpx;
}

/* 背景光晕 */
.bg-glow {
  position: fixed;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  filter: blur(120rpx);
  z-index: -1;
  opacity: 0.15;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-cyan);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-purple);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-right: -12rpx;
}

.store-name {
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.3);
}

.table-info {
  display: block;
  font-size: 24rpx;
  color: var(--neon-cyan);
  margin-top: 4rpx;
}

.cs-btn {
  margin: 0;
  width: auto;
  min-width: 120rpx;
  height: 64rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.cs-icon {
  margin-right: 8rpx;
}

/* 公告栏 */
.notice-section {
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 16rpx;
}

.notice-swiper {
  height: 64rpx;
}

.notice-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.notice-tag {
  background: var(--neon-pink);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.notice-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 菜品精选 */
.dish-section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.more-link {
  font-size: 24rpx;
  color: var(--neon-cyan);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.dish-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.dish-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.dish-meta {
  flex: 1;
  min-width: 0;
}

.dish-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.dish-name {
  display: block;
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.dish-soldout {
  font-size: 20rpx;
  color: #fecaca;
  border: 1rpx solid rgba(248, 113, 113, 0.5);
  background: rgba(248, 113, 113, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.dish-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dish-price {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: var(--neon-cyan);
  font-weight: bold;
}

/* 评价系统 */
.comment-section {
  padding: 24rpx;
  margin-bottom: 85rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 24rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.rating {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.star {
  font-size: 20rpx;
  line-height: 1;
  display: inline-block;
}

.comment-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.comment-date {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* 底部操作 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.order-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}
