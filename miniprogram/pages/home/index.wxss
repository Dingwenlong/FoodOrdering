.container {
  min-height: 100vh;
  position: relative;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.2;
  z-index: 0;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-purple);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-cyan);
}

.main-area {
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
}

.welcome-section {
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
}

.welcome-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.emoji {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--glass-text-sub);
}

.order-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.quick-actions {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  margin-top: 18rpx;
  width: 100%;
}

.quick-btn {
  flex: 1;
  width: 0;
  min-width: 0;
  min-height: 78rpx;
  height: 78rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 28rpx;
  line-height: 1.2;
  margin: 0;
  padding: 0 12rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.error-box {
  border-radius: 14rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.55);
  background: rgba(248, 113, 113, 0.16);
  color: #ffe4e6;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.notice-section {
  margin-bottom: 30rpx;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-card {
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.notice-icon {
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  border-radius: 50%;
  background: rgba(34, 211, 238, 0.16);
  border: 1rpx solid rgba(34, 211, 238, 0.36);
  color: #67e8f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.notice-content {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-text {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-arrow {
  flex: 0 0 28rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 44rpx;
  line-height: 1;
}

.comments-section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.section-subtitle {
  color: rgba(255, 255, 255, 0.46);
  font-size: 24rpx;
}

.notice-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(4, 10, 24, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 44rpx;
  box-sizing: border-box;
}

.notice-modal {
  width: 100%;
  max-height: 72vh;
  padding: 32rpx;
}

.notice-modal-eyebrow {
  display: block;
  color: #67e8f9;
  font-size: 22rpx;
  font-weight: 900;
}

.notice-modal-title {
  display: block;
  margin-top: 12rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
}

.notice-modal-body {
  max-height: 420rpx;
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.notice-modal-btn {
  width: 100%;
  height: 82rpx;
  margin-top: 26rpx;
  font-size: 28rpx;
}

.comments-scroll {
  width: 100%;
  white-space: nowrap;
}

.comment-list {
  display: flex;
  gap: 20rpx;
  padding-right: var(--page-px);
}

.comment-card {
  width: 540rpx;
  flex-shrink: 0;
  padding: 28rpx 24rpx;
  white-space: normal;
}

.comment-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.rating {
  display: flex;
}

.star {
  font-size: 24rpx;
}

.comment-text {
  font-size: 28rpx;
  color: var(--glass-text-main);
  display: block;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-date {
  font-size: 24rpx;
  color: var(--glass-text-sub);
}

.loading-area {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
}
