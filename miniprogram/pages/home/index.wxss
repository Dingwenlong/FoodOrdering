.container {
  min-height: 100vh;
  position: relative;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.2;
  z-index: 0;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-purple);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-cyan);
}

.main-area {
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
}

.welcome-section {
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
}

.welcome-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.emoji {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--glass-text-sub);
}

.order-btn {
  height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.error-box {
  border-radius: 14rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.55);
  background: rgba(248, 113, 113, 0.16);
  color: #ffe4e6;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.comments-section {
  margin-top: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.comments-scroll {
  width: 100%;
  white-space: nowrap;
}

.comment-list {
  display: flex;
  gap: 20rpx;
  padding-right: var(--page-px);
}

.comment-card {
  width: 540rpx;
  flex-shrink: 0;
  padding: 28rpx 24rpx;
  white-space: normal;
}

.comment-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.rating {
  display: flex;
}

.star {
  font-size: 24rpx;
}

.comment-text {
  font-size: 28rpx;
  color: var(--glass-text-main);
  display: block;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-date {
  font-size: 24rpx;
  color: var(--glass-text-sub);
}

.loading-area {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
}
