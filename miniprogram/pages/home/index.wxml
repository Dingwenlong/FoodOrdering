<view class="container">
  <!-- 背景光晕 -->
  <view class="bg-glow bg-glow-1"></view>
  <view class="bg-glow bg-glow-2"></view>

  <!-- 主内容区域 -->
  <view class="main-area safe-area" wx:if="{{!loading}}">
    <!-- 欢迎区域 -->
    <view class="welcome-section glass-card">
      <view class="welcome-header">
        <text class="emoji">👋</text>
        <view class="welcome-text">
          <text class="title">欢迎光临</text>
          <text class="subtitle" wx:if="{{tableName}}">{{tableName}}</text>
          <text class="subtitle" wx:else>请先扫码绑定桌号</text>
        </view>
      </view>

      <!-- 开始点餐按钮 -->
      <button class="order-btn neon-btn" hover-class="btn-hover" bindtap="{{tableName ? 'goMenu' : 'goScan'}}">
        {{tableName ? '开始点餐' : '去绑定桌号'}}
      </button>

      <view class="quick-actions" wx:if="{{tableName}}">
        <button class="quick-btn" hover-class="btn-hover" bindtap="goOrders">我的订单</button>
        <button class="quick-btn" hover-class="btn-hover" bindtap="goSupport">联系客服</button>
      </view>
    </view>

    <!-- 错误信息 -->
    <view class="error-box" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <!-- 系统公告 -->
    <view class="notice-section" wx:if="{{notices.length > 0}}">
      <view class="section-header">
        <text class="section-title">系统公告</text>
        <text class="section-subtitle">最新通知</text>
      </view>

      <view class="notice-list">
        <view
          class="notice-card glass-card"
          wx:for="{{notices}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="openNotice"
        >
          <view class="notice-icon">i</view>
          <view class="notice-content">
            <text class="notice-title">{{item.title}}</text>
            <text class="notice-text">{{item.content}}</text>
          </view>
          <text class="notice-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 顾客评价 -->
    <view class="comments-section" wx:if="{{comments.length > 0}}">
      <view class="section-header">
        <text class="section-title">顾客评价</text>
      </view>

      <scroll-view class="comments-scroll" scroll-x show-scrollbar="{{false}}">
        <view class="comment-list">
          <view class="comment-card glass-card" wx:for="{{comments}}" wx:key="id">
            <view class="comment-user">
              <text class="user-name">{{item.userName}}</text>
              <view class="rating">
                <text class="star" wx:for="{{5}}" wx:for-item="s" wx:for-index="si" wx:key="si">
                  {{si < item.rating ? '⭐' : '☆'}}
                </text>
              </view>
            </view>
            <text class="comment-text">{{item.content}}</text>
            <text class="comment-date">{{item.createdAt}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="notice-modal-mask" wx:if="{{selectedNotice}}" catchtap="closeNotice">
    <view class="notice-modal glass-card" catchtap="noop">
      <text class="notice-modal-eyebrow">系统公告</text>
      <text class="notice-modal-title">{{selectedNotice.title}}</text>
      <scroll-view class="notice-modal-body" scroll-y>
        <text>{{selectedNotice.content}}</text>
      </scroll-view>
      <button class="notice-modal-btn neon-btn" bindtap="closeNotice">知道了</button>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-area" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
