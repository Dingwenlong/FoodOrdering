<view class="container">
  <!-- 简化背景光晕，去掉复杂动画 -->
  <view class="bg-glow bg-glow-1"></view>
  <view class="bg-glow bg-glow-2"></view>

  <view class="welcome-card glass-card">
    <view class="header-text">
      <!-- 去掉Logo，先确保文字能显示 -->
      <view class="logo-area">
        <text class="logo-icon">🍜</text>
      </view>
      <text class="title">未来餐厅</text>
      <text class="subtitle">扫码绑定桌台，快速开始点餐</text>
    </view>

    <view class="error-box" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <view class="action-area">
      <button
        class="scan-btn neon-btn"
        hover-class="btn-hover"
        bindtap="handleScan"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        <text class="icon-scan">📷</text> 扫描桌码点餐
      </button>

      <button
        class="manual-btn glass-btn-secondary"
        hover-class="btn-hover"
        bindtap="handleManual"
        disabled="{{loading}}"
      >
        手动绑定并进入
      </button>

      <view class="manual-form" wx:if="{{showManualForm}}">
        <view class="field">
          <text class="field-label">门店ID</text>
          <input
            class="field-input"
            value="{{manualStoreId}}"
            placeholder="请输入门店ID"
            placeholder-class="field-placeholder"
            bindinput="handleManualStoreInput"
            disabled="{{loading}}"
          />
        </view>

        <view class="field">
          <text class="field-label">桌台ID</text>
          <input
            class="field-input"
            value="{{manualTableId}}"
            placeholder="请输入桌台ID"
            placeholder-class="field-placeholder"
            bindinput="handleManualTableInput"
            disabled="{{loading}}"
          />
        </view>

        <button
          class="confirm-btn neon-btn"
          hover-class="btn-hover"
          bindtap="handleManualSubmit"
          loading="{{loading}}"
          disabled="{{loading}}"
        >
          确认绑定
        </button>
      </view>
    </view>
  </view>
</view>
