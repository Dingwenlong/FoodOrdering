.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: var(--page-px);
  position: relative;
}

/* 简化背景光晕 */
.bg-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.2;
  z-index: 0;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-purple);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-cyan);
}

.welcome-card {
  position: relative;
  z-index: 1;
  width: 88%;
  max-width: 680rpx;
  padding: 56rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-area {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo-icon {
  font-size: 60rpx;
}

.header-text {
  text-align: center;
  margin-bottom: 34rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--glass-text-sub);
}

.error-box {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.55);
  background: rgba(248, 113, 113, 0.16);
  color: #ffe4e6;
  padding: 14rpx 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.action-area {
  width: 100%;
}

.scan-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.manual-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
