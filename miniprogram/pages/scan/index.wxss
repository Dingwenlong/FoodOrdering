.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光效 */
.bg-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
  z-index: -1;
  animation: pulse 8s infinite alternate;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-purple);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-cyan);
  animation-delay: 1s;
}

@keyframes pulse {
  0% { opacity: 0.3; transform: scale(0.9); }
  100% { opacity: 0.5; transform: scale(1.1); }
}

.welcome-card {
  width: 80%;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -60rpx;
  animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.logo-area {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 0 40rpx rgba(34, 211, 238, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo-icon {
  font-size: 60rpx;
}

.header-text {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--glass-text-sub);
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.action-area {
  width: 100%;
}

.scan-btn {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
}

.manual-btn {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.tips {
  margin-top: 60rpx;
  color: var(--glass-text-sub);
  font-size: 24rpx;
  opacity: 0.6;
  letter-spacing: 2rpx;
}

.footer {
  position: absolute;
  bottom: 40rpx;
}

.brand {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 4rpx;
}
