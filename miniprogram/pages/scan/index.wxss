.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: var(--page-px);
  position: relative;
  overflow: hidden;
}

.bg-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
  z-index: -1;
  animation: pulse 8s infinite alternate;
}

.bg-glow-1 {
  top: -100rpx;
  left: -100rpx;
  background: var(--neon-purple);
}

.bg-glow-2 {
  bottom: -100rpx;
  right: -100rpx;
  background: var(--neon-cyan);
  animation-delay: 1s;
}

@keyframes pulse {
  0% { opacity: 0.3; transform: scale(0.9); }
  100% { opacity: 0.5; transform: scale(1.1); }
}

.welcome-card {
  width: 88%;
  max-width: 680rpx;
  padding: 56rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -40rpx;
  animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.logo-area {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28rpx;
  box-shadow: 0 0 40rpx rgba(34, 211, 238, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo-image {
  width: 112rpx;
  height: 112rpx;
}

.header-text {
  text-align: center;
  margin-bottom: 34rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--glass-text-sub);
  letter-spacing: 1rpx;
}

.binding-info {
  width: 100%;
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background: rgba(16, 185, 129, 0.16);
  border: 1rpx solid rgba(16, 185, 129, 0.36);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.binding-text {
  font-size: 28rpx;
  color: #f0fdf4;
}

.mini-action {
  margin: 0;
  width: 200rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
}

.manual-form {
  width: 100%;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.field-row + .field-row {
  margin-top: 14rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.field-input {
  width: 100%;
  min-height: var(--tap-min);
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.placeholder {
  color: rgba(255, 255, 255, 0.38);
}

.error-box {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(248, 113, 113, 0.55);
  background: rgba(248, 113, 113, 0.16);
  color: #ffe4e6;
  padding: 14rpx 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.action-area {
  width: 100%;
}

.scan-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.manual-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.tips {
  margin-top: 40rpx;
  color: var(--glass-text-sub);
  font-size: 28rpx;
  opacity: 0.78;
  text-align: center;
}

.footer {
  position: absolute;
  bottom: calc(var(--safe-bottom-gap) + var(--safe-bottom));
}

.brand {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.22);
  letter-spacing: 4rpx;
}
